<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window when the process first starts before
         Flutter renders its first frame. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
    <!-- Theme applied to the Android Window as Flutter renders its first frame.
         The NormalTheme is applied once that first frame renders. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
